import cv2, numpy as np, time
from PIL import Image
import sys
sys.path.insert(0, "/workspace/echovision")
from core.config import *
from core.firebase import get_sticker_table
from modules.identify import db_lookup, db_save
from modules.describe import run_yolo, run_midas, _depth_score, _depth_label, _pos_label, _map_label

# ─────────────────────────────────────────────────────────────────────────────
# STICKER HELPERS
# ─────────────────────────────────────────────────────────────────────────────

def get_sticker_profile():
    records = [doc.to_dict() for doc in get_sticker_table().stream()]
    return records[0] if records else None

def setup_sticker(color, shape):
    color, shape = color.lower().strip(), shape.lower().strip()
    table = get_sticker_table()
    existing = [doc.to_dict() for doc in table.stream()]
    if existing:
        return existing[0]
    if color not in SUPPORTED_COLORS:
        return f"Unsupported color: {color}."
    if shape not in SUPPORTED_SHAPES:
        return f"Unsupported shape: {shape}."
    profile = {"color": color, "shape": shape}
    table.add(profile)
    return profile

def _get_color_mask(hsv, color):
    ranges = COLOR_PROFILES[color]
    mask = cv2.inRange(hsv, np.array(ranges[0][0]), np.array(ranges[0][1]))
    for lower, upper in ranges[1:]:
        mask = cv2.bitwise_or(mask, cv2.inRange(hsv, np.array(lower), np.array(upper)))
    return mask

def _detect_shape(mask, shape):
    kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (5,5))
    mask = cv2.morphologyEx(cv2.morphologyEx(mask, cv2.MORPH_CLOSE, kernel), cv2.MORPH_OPEN, kernel)
    h, w = mask.shape
    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    for cnt in contours:
        area = cv2.contourArea(cnt)
        if not (200 <= area <= 15000): continue
        M = cv2.moments(cnt)
        if M["m00"] == 0: continue
        cx_c = int(M["m10"]/M["m00"])
        cy_c = int(M["m01"]/M["m00"])
        if not (w*0.05 <= cx_c <= w*0.95 and h*0.05 <= cy_c <= h*0.95): continue
        peri = cv2.arcLength(cnt, True)
        if peri == 0: continue
        circularity = 4*np.pi*area/(peri*peri)
        bw, bh = cv2.boundingRect(cnt)[2:]
        aspect = bw/float(bh) if bh > 0 else 0
        corners = len(cv2.approxPolyDP(cnt, 0.04*peri, True))
        if shape == "circle"    and circularity >= 0.60 and 0.5 <= aspect <= 1.5: return True
        if shape == "triangle"  and corners == 3: return True
        if shape == "square"    and corners == 4 and 0.75 <= aspect <= 1.25: return True
        if shape == "rectangle" and 4 <= corners <= 6 and aspect >= 0.2: return True
    return False

def validate_sticker(frame_bgr):
    profile = get_sticker_profile()
    if profile is None: return False
    hsv = cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2HSV)
    mask = _get_color_mask(hsv, profile["color"])
    return _detect_shape(mask, profile["shape"])

# ─────────────────────────────────────────────────────────────────────────────
# STICKER MULTI-FRAME VALIDATION
# ─────────────────────────────────────────────────────────────────────────────

_sticker_frames_collected  = []
_sticker_collection_active = False
_STICKER_TOTAL_FRAMES      = 10
_STICKER_MIN_CONFIRMS      = 3

def reset_sticker_collection():
    global _sticker_frames_collected, _sticker_collection_active
    _sticker_frames_collected  = []
    _sticker_collection_active = False

def start_sticker_collection():
    global _sticker_frames_collected, _sticker_collection_active
    _sticker_frames_collected  = []
    _sticker_collection_active = True

def add_sticker_frame(frame_bgr):
    global _sticker_frames_collected, _sticker_collection_active
    if not _sticker_collection_active:
        return "collecting"
    frame_cv = (cv2.cvtColor(np.array(frame_bgr), cv2.COLOR_RGB2BGR)
                if not isinstance(frame_bgr, np.ndarray) else frame_bgr)
    _sticker_frames_collected.append(validate_sticker(frame_cv))
    collected = len(_sticker_frames_collected)
    confirms  = sum(_sticker_frames_collected)
    if confirms >= _STICKER_MIN_CONFIRMS:
        reset_sticker_collection()
        return "confirmed"
    if collected >= _STICKER_TOTAL_FRAMES:
        reset_sticker_collection()
        return "failed"
    return "collecting"

# ─────────────────────────────────────────────────────────────────────────────
# SURFACE HELPER
# ─────────────────────────────────────────────────────────────────────────────

def _find_surface(matched_box, all_dets, frame_h=None):
    x1,y1,x2,y2 = matched_box
    item_cx   = (x1+x2)/2
    tolerance = (frame_h*0.10) if frame_h else 30
    candidates = []
    for d in all_dets:
        if d["label"].lower() not in SURFACE_CLASSES_LOWER: continue
        sx1,sy1,sx2,sy2 = d["box_xyxy"]
        if (y2 >= sy1-tolerance and y2 <= sy2+tolerance
                and (sx1 <= item_cx <= sx2 or not (x2 < sx1 or x1 > sx2))):
            candidates.append(d["label"].lower())
    if not candidates: return None
    for preferred in SURFACE_PRIORITY:
        if preferred in candidates: return f"on the {preferred}"
    return f"on the {candidates[0]}"

# ─────────────────────────────────────────────────────────────────────────────
# OBSTACLE HELPERS
# ─────────────────────────────────────────────────────────────────────────────

def _which_side_clearer(dets, W):
    mid = W / 2
    left_count  = sum(1 for d in dets
                      if d["label"].lower() in OBSTACLE_CLASSES_LOWER
                      and (d["box_xyxy"][0] + d["box_xyxy"][2]) / 2 < mid)
    right_count = sum(1 for d in dets
                      if d["label"].lower() in OBSTACLE_CLASSES_LOWER
                      and (d["box_xyxy"][0] + d["box_xyxy"][2]) / 2 >= mid)
    return "left" if right_count > left_count else "right"

# ─────────────────────────────────────────────────────────────────────────────
# SCAN HELPER
# ─────────────────────────────────────────────────────────────────────────────

def scan_for_item(item_name, frame_bgr, models):
    dets = run_yolo(frame_bgr, models, conf=0.10)
    matches = [d for d in dets if
               _map_label(d["label"]) == item_name.lower() or
               d["label"].lower() == item_name.lower()]
    if not matches: return []
    img_pil   = Image.fromarray(cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2RGB))
    depth_map = run_midas(img_pil, models)
    W, H      = img_pil.size
    results   = []
    for matched in sorted(matches, key=lambda d: d.get("conf",0), reverse=True):
        x1,y1,x2,y2 = matched["box_xyxy"]
        ds       = _depth_score(depth_map, matched["box_xyxy"], W, H)
        distance = _depth_label(ds)
        vert, horiz = _pos_label((x1+x2)/2,(y1+y2)/2,W,H)
        surface  = _find_surface(matched["box_xyxy"], dets, frame_h=H)
        horiz_str = {"left":"to your left","center":"directly in front of you","right":"to your right"}.get(horiz,"in front of you")
        vert_str  = {"top":", on the far side","middle":"","bottom":", close to you"}.get(vert,"")
        location_hint = f"{surface}, {horiz_str}{vert_str}" if surface else f"{horiz_str}{vert_str}"
        results.append({
            "label":         matched["label"],
            "conf":          matched.get("conf",0),
            "box_xyxy":      matched["box_xyxy"],
            "location_hint": location_hint,
            "distance":      distance,
            "depth_score":   ds,
        })
    return results

# ─────────────────────────────────────────────────────────────────────────────
# STEP 1 — ROOM SCAN
# ─────────────────────────────────────────────────────────────────────────────

def run_find_scan(item_name, frame_bgr, models, scan_attempt=1):
    if not item_name or not item_name.strip():
        return {"status": "error", "message": "Item name is missing. Please try again."}
    record = db_lookup(item_name)
    if record is None:
        return {"status": "not_registered",
                "message": (f"Your {item_name} has not been registered. "
                            f"Please say identify my {item_name} followed by the room name first.")}
    profile = get_sticker_profile()
    if profile is None:
        return {"status": "no_sticker", "message": "No sticker profile found. Please set up your sticker first."}
    if scan_attempt > 3:
        return {"status": "give_up",
                "message": (f"I was unable to find your {item_name} after 3 attempts. "
                            f"It may have been moved. Please say identify my {item_name} to register its new location.")}
    if scan_attempt == 2:
        guidance = "Scan 2 of 3. Try raising the camera slightly and scan left to right slowly. "
    elif scan_attempt == 3:
        guidance = "Last scan. Please turn around slowly and keep the camera steady. "
    else:
        guidance = ""
    matches = scan_for_item(item_name, frame_bgr, models)
    if not matches:
        return {"status": "not_found",
                "message": (f"{guidance}I could not find your {item_name} in the room. "
                            f"Move the camera slowly from left to right."),
                "scan_attempt": scan_attempt}
    matches = sorted(matches, key=lambda x: x["conf"], reverse=True)[:3]
    best    = matches[0]
    if best["conf"] < 0.35:
        message = (f"I think I can see your {item_name} {best['location_hint']}, "
                   f"but I am not fully sure. Walk toward it carefully.")
    else:
        message = (f"Your {item_name} seems to be {best['location_hint']}. "
                   f"I will guide you as you walk.")
    return {"status": "found", "message": message, "matches": matches,
            "record": record, "scan_attempt": scan_attempt}

# ─────────────────────────────────────────────────────────────────────────────
# STEP 2A — OBSTACLE CHECK  (called every 800ms)
# FAST: YOLO only, no MiDaS
# SMART: center path only, box size for distance
# NOT REPETITIVE: same obstacle repeats only after 4 seconds
# ─────────────────────────────────────────────────────────────────────────────

_last_obstacle_label     = None
_last_obstacle_warn_time = 0.0

def run_obstacle_check(frame_bgr, target_box, excluded_boxes, models):
    global _last_obstacle_label, _last_obstacle_warn_time

    dets   = run_yolo(frame_bgr, models, conf=0.40)
    H, W   = frame_bgr.shape[:2]

    def _overlap(a, b, thr=0.4):
        x1 = max(a[0],b[0]); y1 = max(a[1],b[1])
        x2 = min(a[2],b[2]); y2 = min(a[3],b[3])
        inter = max(0,x2-x1)*max(0,y2-y1)
        if inter == 0: return False
        area_a = (a[2]-a[0])*(a[3]-a[1])
        area_b = (b[2]-b[0])*(b[3]-b[1])
        union  = area_a + area_b - inter
        return (inter/union) >= thr if union > 0 else False

    center_left  = W * 0.25
    center_right = W * 0.75
    closest_obstacle = None
    closest_ratio    = 0.0

    for d in dets:
        if d["label"].lower() not in OBSTACLE_CLASSES_LOWER: continue
        box = d["box_xyxy"]
        if target_box and _overlap(box, target_box): continue
        if any(_overlap(box, ex) for ex in (excluded_boxes or [])): continue
        x1, y1, x2, y2 = box
        cx = (x1 + x2) / 2
        if not (center_left <= cx <= center_right): continue
        box_h = y2 - y1
        ratio = box_h / H
        if ratio < 0.20: continue
        if ratio > closest_ratio:
            closest_ratio    = ratio
            closest_obstacle = {"label": d["label"], "box": box, "ratio": ratio}

    if not closest_obstacle:
        return None

    label = closest_obstacle["label"]
    ratio = closest_obstacle["ratio"]
    now   = time.time()

    same_obstacle = (label.lower() == (_last_obstacle_label or "").lower())
    time_passed   = (now - _last_obstacle_warn_time) >= 4.0

    if same_obstacle and not time_passed:
        return None

    _last_obstacle_label     = label
    _last_obstacle_warn_time = now

    side = _which_side_clearer(dets, W)

    if ratio >= 0.55:
        return f"Stop. {label.capitalize()} right in front of you. Move to the {side}."
    else:
        return f"{label.capitalize()} ahead. Move to the {side}."

# ─────────────────────────────────────────────────────────────────────────────
# STEP 2B — WALK FRAME  (called every 1500ms)
# ─────────────────────────────────────────────────────────────────────────────

_last_direction = None
_item_reached   = False

def run_find_walk_frame(item_name, frame_bgr, target_box, excluded_boxes, models):
    global _last_direction, _last_obstacle_warn_time, _item_reached

    img_pil   = Image.fromarray(cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2RGB))
    dets      = run_yolo(frame_bgr, models, conf=0.10)
    depth_map = run_midas(img_pil, models)
    W, H      = img_pil.size

    def _overlap(a, b, thr=0.4):
        x1 = max(a[0],b[0]); y1 = max(a[1],b[1])
        x2 = min(a[2],b[2]); y2 = min(a[3],b[3])
        inter = max(0,x2-x1)*max(0,y2-y1)
        if inter == 0: return False
        area_a = (a[2]-a[0])*(a[3]-a[1])
        area_b = (b[2]-b[0])*(b[3]-b[1])
        union  = area_a + area_b - inter
        return (inter/union) >= thr if union > 0 else False

    def _loose_match(box):
        if target_box is None: return True
        return _overlap(box, target_box, thr=0.15)

    for d in dets:
        mapped = _map_label(d["label"])
        if mapped != item_name.lower() and d["label"].lower() != item_name.lower():
            continue
        box = d["box_xyxy"]
        if any(_overlap(box, ex) for ex in (excluded_boxes or [])): continue
        if not _loose_match(box): continue

        x1,y1,x2,y2 = box
        vert, horiz  = _pos_label((x1+x2)/2,(y1+y2)/2,W,H)
        ds           = _depth_score(depth_map, box, W, H)
        dl           = _depth_label(ds)

        if dl == "near" and not _item_reached:
            _item_reached = True
            _last_direction = None
            reset_sticker_collection()
            start_sticker_collection()
            return {
                "status":         "reached",
                "message":        f"Stop. Your {item_name} is right in front of you. Hold it up to the camera for validation.",
                "obstacle":       None,
                "new_target_box": box,
            }

        horiz_str = {
            "left":   f"move right, your {item_name} is to your left",
            "center": f"go straight, your {item_name} is ahead",
            "right":  f"move left, your {item_name} is to your right"
        }.get(horiz, f"go straight toward your {item_name}")

        vert_str = {
            "top":    ", still far ahead",
            "middle": "",
            "bottom": ", almost there"
        }.get(vert, "")

        hint = f"{horiz_str}{vert_str}"

        now = time.time()
        obstacle_pause    = (now - _last_obstacle_warn_time) < 2.0
        direction_changed = (horiz != _last_direction)

        item_message = None
        if direction_changed and not obstacle_pause:
            item_message    = hint
            _last_direction = horiz

        return {
            "status":         "walking",
            "message":        item_message,
            "obstacle":       None,
            "new_target_box": box,
        }

    _item_reached = False
    return {
        "status":         "lost",
        "message":        f"Still searching for your {item_name}. Move the camera slowly.",
        "obstacle":       None,
        "new_target_box": target_box,
    }

# ─────────────────────────────────────────────────────────────────────────────
# STEP 3 — STICKER VALIDATION (multi-frame)
# ─────────────────────────────────────────────────────────────────────────────

def run_sticker_validate(frame_bgr, item_name="item"):
    result = add_sticker_frame(frame_bgr)
    if result == "collecting":
        return {"confirmed": False, "message": None, "status": "collecting",
                "progress": len(_sticker_frames_collected)}
    elif result == "confirmed":
        _item_reached_reset()
        return {"confirmed": True, "message": f"Confirmed. This is your {item_name}.",
                "status": "confirmed"}
    else:
        _item_reached_reset()
        return {"confirmed": False,
                "message": (f"I could not detect your sticker on the {item_name}. "
                            f"Turn it slowly toward the camera and make sure the light is good."),
                "status": "not_confirmed"}

def _item_reached_reset():
    global _item_reached, _last_direction
    _item_reached   = False
    _last_direction = None